{
  "name": "stellarsignal",
  "private": true,
  "type": "module",
  "scripts": {
    "install:frontend": "cd Frontend && bun install",
    "dev:api": "tsx services/api-server/src/index.ts",
    "dev:agent": "tsx services/agent/src/index.ts",
    "dev:frontend": "cd Frontend && bun run dev",
    "build": "tsc -p services/api-server/tsconfig.json && tsc -p services/agent/tsconfig.json",
    "build:frontend": "cd Frontend && bun run build",
    "fund-wallets": "tsx scripts/fund-wallets.ts",
    "setup-usdc": "tsx scripts/setup-usdc-trustlines.ts"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^13.3.0",
    "@x402/core": "latest",
    "@x402/express": "latest",
    "@x402/fetch": "latest",
    "@x402/stellar": "latest",
    "dotenv": "^16.4.7",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
